VITE_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=SUA_ANON_KEY_AQUI

# Backend — PagBank
# Obtenha o token no painel do PagBank: Minha Conta > Integrações > Tokens e Chaves
PAGBANK_TOKEN=SEU_TOKEN_PAGBANK_AQUI
# "sandbox" para testes, "production" para produção
PAGBANK_ENV=sandbox

# Backend — Supabase (service_role key — NÃO é a anon key)
# Painel Supabase > Project Settings > API > service_role
SUPABASE_SERVICE_KEY=SUA_SERVICE_ROLE_KEY_AQUI
