{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "neuralhub.ia.br" }],
      "destination": "https://neuralhub.ia.br/neuralhub.html",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "neuralhub.ia.br" }],
      "destination": "/neuralhub.html"
    },
    { "source": "/neuralhub", "destination": "/neuralhub.html" },
    { "source": "/neuralhub/(.*)", "destination": "/neuralhub.html" },
    { "source": "/obrigado", "destination": "/obrigado.html" },
    { "source": "/lead", "destination": "/lead.html" },
    { "source": "/brand", "destination": "/brand.html" },
    { "source": "/plataforma", "destination": "/plataforma.html" },
    { "source": "/plataforma/(.*)", "destination": "/plataforma.html" },
    { "source": "/blog", "destination": "/index.html" },
    { "source": "/blog/(.*)", "destination": "/index.html" }
  ]
}
